#include <stdio.h>
int main()
{
    int size,sum=0;
    float avg;
    scanf("%d",&size);
    int arr[size];
    for(int i=0; i<size; i++)
    {
      scanf("%d",&arr[i]);  
    }
    for(int i=0; i<size; i++)
    {
        sum+=arr[i];
    }
    avg=sum/size;
    printf("%d\n",sum);
    printf("%f",avg);
    return 0;
}

#include <stdio.h>
int main()
{
    int n=4,arr[4]={1,4,6,8};
    int target=10;
    for(int i=0; i<n; i++)
    {
        for(int j=i+1; j<n; j++)
        {
            if(arr[i]+arr[j]==target)
            {
                printf("%d %d",arr[i],arr[j]);
            }
        }
    }
    return 0;
}

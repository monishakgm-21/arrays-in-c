#include <stdio.h> 
int main()
{
    int arr[5]={4,32,567,28,789};
    int size=5;
    int max,min;
    max=arr[0];
    min=arr[0];
    for(int i=1; i<size; i++)
    {
        if(arr[i]>max)
        {
            max=arr[i];
        }
        if(arr[i]<min)
        {
            min=arr[i];
        }
    }
    printf("%d",max);
    printf("\n%d",min);
    return 0;
}

#include <stdio.h>
int main()
{
    int size,pos=0,neg=0,zero=0;
    scanf("%d",&size);
    int arr[size];
    for(int i=0; i<size; i++)
    {
        scanf("%d",&arr[i]);
    }
    for(int i=0; i<size; i++)
    {
        if(arr[i]>0)
        {
         pos++;  
        }
        else if(arr[i]<0)
        {
          neg++;  
        }
        else
        {
            zero++;
        }
    }
    printf("%d",pos);
    printf("%d",neg);
    printf("%d",zero);
    return 0;
}

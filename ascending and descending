#include <stdio.h>
int main()
{
    int size=5,arr[5]={3,6,4,8,9};
    for(int i=0; i<size-1; i++)
    {
        for(int j=i+1; j<size; j++)
        {
            if(arr[j]<arr[i])
            {
               int temp=arr[i];
               arr[i]=arr[j];
               arr[j]=temp;
            }
        }
    }
    
    for(int i=0; i<size; i++)
    {
        printf("%d",arr[i]);
    }
    for(int i=size-1; i>=0; i--)
    {
       printf("\n%d",arr[i]);
    }
    return 0;
}
